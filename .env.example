# Copie ce fichier en .env et remplis les valeurs

# Secret JWT (génère avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change_me_secret_jwt_64chars

# Clé API Bearer (génère avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
API_KEY=change_me_api_key_32chars

# Environnement
NODE_ENV=development

# Origines autorisées (CORS)
ALLOWED_ORIGINS=http://localhost:3000
